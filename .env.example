# ==========================================
# 一念通玄 · 六爻占卜 — 环境变量配置
# ==========================================
# 复制此文件为 .env.local 并填入实际值
# cp .env.example .env.local

# ==========================================
# 广告系统 (Ad System)
# ==========================================
# 广告模式判定规则（按优先级）：
#   1. 若 NEXT_PUBLIC_ADSENSE_CLIENT_ID 有值 → 启用 Google AdSense 模式
#   2. 否则若 NEXT_PUBLIC_AD_CUSTOM_ADS 有值 → 启用多条自定义推广链接模式
#   3. 否则若 NEXT_PUBLIC_AD_CUSTOM_URL 有值 → 启用单条自定义推广链接模式（旧版兼容）
#   4. 三者皆空 → 不显示任何广告

# ---- Google AdSense ----
# Google AdSense 发布商 ID（格式：ca-pub-XXXXXXXXXXXXXXXX）
# 在 AdSense 后台 → 账号 → 账号信息 → 发布商 ID 获取
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# ---- 多条自定义推广链接（推荐） ----
# JSON 数组格式，每项包含 url（推广链接）、text（展示文案）、label（平台标签，选填）
# 多个 AdBanner 实例会随机展示不同广告，增加推广多样性
# 示例：京东联盟 + 淘宝客
# NEXT_PUBLIC_AD_CUSTOM_ADS=[{"url":"https://你的京东联盟链接","text":"正版易经书籍推荐","label":"京东"},{"url":"https://你的淘宝客链接","text":"开光铜钱三枚装","label":"淘宝"}]
NEXT_PUBLIC_AD_CUSTOM_ADS=

# ---- 单条自定义推广链接（旧版兼容） ----
# 仅在 NEXT_PUBLIC_AD_CUSTOM_ADS 为空时生效
# 自定义推广链接（直接推广链接赚佣金，如淘宝客/京东联盟等）
NEXT_PUBLIC_AD_CUSTOM_URL=

# 自定义推广链接的展示文案（可选，留空则显示默认文案）
NEXT_PUBLIC_AD_CUSTOM_TEXT=

# ==========================================
# Supabase
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ==========================================
# 通义千问 API (AI 解卦)
# ==========================================
DASHSCOPE_API_KEY=
